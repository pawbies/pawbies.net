<div id="guests" class="relative">
  <%# tape, lilac %>
  <div class="absolute h-[18px] w-[70px] rotate-6 shadow-[0_1px_3px_#0003] -top-2 left-[30px] bg-[repeating-linear-gradient(90deg,#d9a7ffaa_0_4px,#d9a7ff55_4px_8px)]"></div>

  <div class="relative bg-paper rounded-sm shadow-[0_6px_20px_#0006,0_1px_0_#00000022] p-4 rotate-[1.95deg]">
    <svg viewBox="0 0 24 24" width="22" height="22" class="absolute -top-3 right-4">
      <path d="M12 21 C 4 15, 2 10, 6 6 C 9 4, 11 6, 12 8 C 13 6, 15 4, 18 6 C 22 10, 20 15, 12 21 Z" fill="none" stroke="#ff2fb3" stroke-width="1.5"/>
    </svg>

    <div class="font-display text-[24px] text-hot mb-2"><%= t(".guestbook") %></div>

    <% [
      { who: "@catjail",    when: "2d", msg: "ur site broke my eyes in the best way <3", tw: "bg-[#7affd333] rotate-[0.6deg]"  },
      { who: "@linuxdweeb", when: "5d", msg: "please open-source femboy.css i need it",  tw: "bg-[#ff94d433] -rotate-[0.6deg]" },
      { who: "@haruka",     when: "1w", msg: "frieren post was beautiful ;_; tysm",      tw: "bg-[#7affd333] rotate-[0.6deg]"  },
      { who: "@benchpress", when: "2w", msg: "how are your wrists so strong",            tw: "bg-[#ff94d433] -rotate-[0.6deg]" }
    ].each do |g| %>
      <div class="font-script text-[15px] mb-1.5 rounded-sm p-2 <%= g[:tw] %>">
        <div class="font-bold text-hot text-[14px]">
          <%= g[:who] %>
          <span class="font-mono text-[11px] text-[#2a1535aa]">· <%= g[:when] %></span>
        </div>
        <div class="leading-[1.2] mt-0.5">"<%= g[:msg] %>"</div>
      </div>
    <% end %>

    <button type="button" class="mt-1.5 w-full font-script font-bold text-[18px] cursor-pointer rounded-sm bg-[linear-gradient(180deg,#ff2fb3,#ff94d4)] border-2 border-plum-deep text-plum-deep px-3 py-1.5 shadow-[2px_2px_0_#1a0822]">
      <%= t(".sign_it") %>
    </button>
  </div>
</div>

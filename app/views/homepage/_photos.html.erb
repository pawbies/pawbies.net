<div id="photos" class="relative">
  <%# tape, hot, top-center %>
  <div class="absolute h-[18px] w-[50px] -rotate-10 shadow-[0_1px_3px_#0003] -top-1.5 left-1/2 -ml-[25px] bg-[repeating-linear-gradient(90deg,#ff2fb3aa_0_4px,#ff2fb355_4px_8px)]"></div>

  <div class="relative rounded-sm shadow-[0_6px_20px_#0006,0_1px_0_#00000022] p-2 rotate-[1.2deg] bg-plum-deep">
    <div class="p-1.5 mb-1.5 bg-paper rotate-[0.5deg]">
      <div class="flex items-center justify-center font-mono text-[10px] uppercase tracking-wider relative overflow-hidden h-[84px] bg-[repeating-linear-gradient(135deg,#3a1d4a_0_12px,#ff6ec722_12px_24px)] text-[#ff6ec7]">
        <span class="rounded-sm bg-[#1a1020cc] px-2 py-[3px] border border-dashed border-[#ff6ec766]">spring '26</span>
      </div>
    </div>
    <div class="p-1.5 mb-1.5 bg-paper -rotate-[0.5deg]">
      <div class="flex items-center justify-center font-mono text-[10px] uppercase tracking-wider relative overflow-hidden h-[84px] bg-[repeating-linear-gradient(135deg,#1f1428_0_12px,#d9a7ff22_12px_24px)] text-lilac">
        <span class="rounded-sm bg-[#1a1020cc] px-2 py-[3px] border border-dashed border-[#d9a7ff66]">gym pr</span>
      </div>
    </div>
    <div class="p-1.5 mb-1.5 bg-paper rotate-[0.5deg]">
      <div class="flex items-center justify-center font-mono text-[10px] uppercase tracking-wider relative overflow-hidden h-[84px] bg-[repeating-linear-gradient(135deg,#4e1e5a_0_12px,#ff2fb322_12px_24px)] text-hot">
        <span class="rounded-sm bg-[#1a1020cc] px-2 py-[3px] border border-dashed border-[#ff2fb366]">cafe</span>
      </div>
    </div>
    <div class="text-center font-script text-[16px] py-1 text-petal"><%= t(".photo_booth") %></div>
  </div>
</div>

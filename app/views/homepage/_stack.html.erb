<div class="relative">
  <%# tape, mint %>
  <div class="absolute h-[18px] w-[60px] -rotate-[5deg] shadow-[0_1px_3px_#0003] -top-1.5 right-[30px] bg-[repeating-linear-gradient(90deg,#7affd3aa_0_4px,#7affd355_4px_8px)]"></div>

  <div class="relative bg-paper rounded-sm shadow-[0_6px_20px_#0006,0_1px_0_#00000022] p-4 -rotate-[0.9deg] border-[2.5px] border-dashed border-[#ff2fb366]">
    <div class="font-display text-[20px] text-hot mb-2"><%= t(".my_stack") %></div>
    <div class="text-[12px] leading-[1.7]">
      <div class="flex gap-2 items-baseline">
        <span class="font-script text-[16px] text-hot min-w-[70px]"><%= t(".editor") %></span>
        <span class="flex-1"><%= t(".editor_stack") %></span>
      </div>
      <div class="flex gap-2 items-baseline">
        <span class="font-script text-[16px] text-hot min-w-[70px]"><%= t(".shell") %></span>
        <span class="flex-1"><%= t(".shell_stack") %></span>
      </div>
      <div class="flex gap-2 items-baseline">
        <span class="font-script text-[16px] text-hot min-w-[70px]"><%= t(".lang") %></span>
        <span class="flex-1"><%= t(".lang_stack") %></span>
      </div>
      <div class="flex gap-2 items-baseline">
        <span class="font-script text-[16px] text-hot min-w-[70px]"><%= t(".os") %></span>
        <span class="flex-1"><%= t(".os_stack") %></span>
      </div>
    </div>
  </div>
</div>
